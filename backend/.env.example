# ─── Server ──────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# ─── Database ────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=medlab_user
DB_PASSWORD=medlab_pass_secure
DB_DATABASE=medlab_pro

# ─── Redis ───────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ─────────────────────────────────────────────
JWT_SECRET=change-this-to-a-strong-random-secret-32-chars-min
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# ─── Firebase ────────────────────────────────────────
FIREBASE_PROJECT_ID=medlab-pro
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@medlab-pro.iam.gserviceaccount.com

# ─── WhatsApp Business API ──────────────────────────
WHATSAPP_API_TOKEN=your-whatsapp-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_VERIFY_TOKEN=your-verify-token

# ─── SMS Gateway ────────────────────────────────────
SMS_API_KEY=your-sms-api-key
SMS_SENDER_ID=MedLabPro

# ─── File Storage (MinIO / S3) ──────────────────────
STORAGE_TYPE=local     # local | s3 | minio
STORAGE_PATH=./uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET=medlab-pro-uploads
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ─── Payment Gateway ────────────────────────────────
PAYMENT_PROVIDER=stripe  # stripe | razorpay
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ─── CORS ────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://admin.medlabpro.com

# ─── Rate Limiting ──────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ─── Email ──────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
EMAIL_FROM=noreply@medlabpro.com