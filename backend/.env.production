# ─── Production Environment Variables ───────────────────
# Copy this file to .env on your production server and fill in the values

NODE_ENV=production
PORT=3000
API_PREFIX=api/v1

# ─── PostgreSQL (REQUIRED) ─────────────────────────────
# Get these from your Render / Railway / Fly.io PostgreSQL dashboard
DB_HOST=your-postgres-host
DB_PORT=5432
DB_USERNAME=your-postgres-user
DB_PASSWORD=your-postgres-password
DB_DATABASE=your-postgres-database

# ─── Redis (optional, for caching) ─────────────────────
# Set DISABLE_CACHE=true if you don't have Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT (REQUIRED — CHANGE THIS!) ─────────────────────
JWT_SECRET=REPLACE-WITH-A-STRONG-RANDOM-SECRET-AT-LEAST-32-CHARS
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# ─── File Storage ──────────────────────────────────────
STORAGE_TYPE=local
STORAGE_PATH=./uploads

# ─── CORS ──────────────────────────────────────────────
CORS_ORIGINS=https://your-dashboard-url.com,https://your-website-url.com

# ─── Rate Limiting ─────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ─── Email (optional) ──────────────────────────────────
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key
# EMAIL_FROM=noreply@medlabpro.com